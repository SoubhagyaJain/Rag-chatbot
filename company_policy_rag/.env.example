# Chroma — disable telemetry (stops posthog capture() errors in logs)
ANONYMIZED_TELEMETRY=False

# Ollama connection
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text

# LLM generation
LLM_TEMPERATURE=0.1
LLM_REQUEST_TIMEOUT=120.0
LLM_CONTEXT_WINDOW=8192

# Retrieval
SIMILARITY_TOP_K=8
RETRIEVAL_CANDIDATE_K=30

# Reranker (local cross-encoder — improves precision on policy/legal docs)
ENABLE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-large
RERANKER_TOP_N=6
RERANKER_BATCH_SIZE=32
# cpu | cuda | cuda:0 | auto (cuda when available, else cpu)
RERANKER_DEVICE=cpu
ENABLE_RERANK_SCORE_FILTER=true
RERANK_MIN_SCORE_RATIO=0.40
RERANK_MIN_KEEP=3

# Query rewrite (LLM → keyword-dense search query before retrieval)
ENABLE_QUERY_REWRITE=true

# Generation / faithfulness grounding
# balanced = helpful + faithful (default); strict = max faithfulness, more abstention
GROUNDING_STRICTNESS=balanced
RESPONSE_PROMPT_VERSION=v2_balanced
STRICT_GROUNDING=false
ENABLE_FAITHFULNESS_CHECK=true
FAITHFULNESS_GUARD_MODE=balanced

# Code validation (Phase 3) — runs after faithfulness guard when answer/context has code
ENABLE_CODE_VALIDATION=true
ENABLE_CODE_SELF_CORRECTION=true
CODE_SELF_CORRECTION_MAX_RETRIES=1
CODE_VALIDATION_USE_HEURISTIC=true

# Response language: english | chinese | match_query (english recommended for qwen2.5)
RESPONSE_LANGUAGE=english

CHUNK_SIZE=640
CHUNK_OVERLAP=64

# Section detection (legal/policy structure metadata)
ENABLE_SECTION_DETECTION=true
SECTION_DETECTION_MODE=standard

# Paths (relative to project root)
DATA_DIR=data
STORAGE_DIR=storage
CHROMA_PERSIST_DIR=storage/chroma
CHROMA_COLLECTION_NAME=company_policies
CHROMA_DISTANCE_FN=cosine
LOGS_DIR=logs

# Conversation memory (per Chainlit session)
ENABLE_CONVERSATION_MEMORY=true
MEMORY_WINDOW_SIZE=5
MEMORY_TOKEN_LIMIT=3000

# Evaluation (golden-set quality gate)
EVAL_LLM_MODEL=qwen2.5:7b
EVAL_MAX_SAMPLES=0
EVAL_USE_LLM_JUDGE=true

# Logging
LOG_LEVEL=INFO

# Chainlit
CHAINLIT_PORT=8000
SHOW_CITATIONS=true
CITATION_MAX_SOURCES=6
CITATION_SHOW_EXCERPTS=true
CITATION_SHOW_SCORE=false
CITATION_DEDUPE=true
CITATION_FORMAT=section_first
CITATION_MIN_RELEVANCE_RATIO=0.55
ENABLE_CITATION_PIPELINE_LOGGING=true